# Ignore everything except directories
*
!*/

################################### WHITELIST ##################################

!PERSONAL.md

# Config
!.config/bash/**/*
!.config/composer/composer.json
!.config/efm-langserver/*
!.config/env/.env.example
!.config/fish/*
!.config/git/**/*
!.config/ghostty/**/*
!.config/hammerspoon/**/*
!.config/mackup/**/*
!.config/mise/**/*
!.config/nix/**/*
!.config/nvim/**/*
!.config/opencode/**/*
!.config/rclone/base_filter.txt
!.config/rclone/code_filter.txt
!.config/rclone/dotfiles_filter.txt
!.config/snippets/**/*
!.config/ssh/config
!.config/vim/**/*
!.config/zsh/**/*

# Dotbot
!dotbot.conf.yaml
!dotbot_uninstall

# Espanso
!.config/espanso/config/default.yml
!.config/espanso/match/coding.yml
!.config/espanso/match/math.yml
!.config/espanso/match/others.yml
!.config/espanso/match/words.yml

# Git
!.github/**/*
!.gitignore
!.gitignore_global
!.gitmodules

# Vim
!minimal.vim
!vim/**/*

# Other dirs
!bin/**/*
!commands/**/*
!misc/packages/**/*
!tasks/**/*
!tests/**/*
!misc/LaunchAgents/**/*

# Other files
!.tool-versions
!.config/.color_mode
!Rakefile
!README.md
!stylua.toml

################################### BLACKLIST ##################################

# Config
.config/hammerspoon/Spoons/*
.config/ghostty/themes

# Fish
.config/fish/fish_variables
.config/fish/fish_history

# Others
.DS_Store
backup
.repro
misc/

